APP_NAME=SaveQue$t API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@POOLED_HOST/savequest?sslmode=require&channel_binding=require
DATABASE_MIGRATION_URL=postgresql+psycopg://USER:PASSWORD@DIRECT_HOST/savequest?sslmode=require&channel_binding=require

DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800